{
  "name": "sessionbox",
  "version": "1.0.0",
  "description": "多沙箱浏览器管理应用 - Chrome 多实例 + 指纹伪造",
  "main": "electron/main.js",
  "type": "module",
  "packageManager": "pnpm@10.6.3",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && cross-env NODE_ENV=development electron .\"",
    "build": "vite build",
    "start": "electron .",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "pack": "pnpm run build && electron-builder --dir",
    "dist": "pnpm run build && electron-builder"
  },
  "keywords": ["electron", "chrome", "sandbox", "fingerprint"],
  "author": "",
  "license": "MIT",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild"
    ]
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "element-plus": "^2.9.0",
    "fs-extra": "^11.2.0",
    "pinia": "^2.3.0",
    "uuid": "^11.0.3",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9",
    "sass": "^1.83.0",
    "vite": "^6.0.5",
    "wait-on": "^8.0.1"
  }
}
