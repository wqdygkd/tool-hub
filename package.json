{
  "name": "tool-hub",
  "version": "1.0.0",
  "description": "Tool Hub 多功能工具平台 - Electron + Vue 3，首个工具 Chrome沙箱 提供多沙箱浏览器管理",
  "main": "electron/main.js",
  "type": "module",
  "packageManager": "pnpm@10.6.3",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && cross-env NODE_ENV=development electron .\"",
    "build": "vite build",
    "start": "electron .",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "pack": "pnpm run build && electron-builder --dir",
    "dist": "pnpm run build && electron-builder"
  },
  "keywords": [
    "electron",
    "chrome",
    "sandbox",
    "fingerprint",
    "multi-tool"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=22.12.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "better-sqlite3",
      "electron",
      "electron-winstaller"
    ]
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "element-plus": "^2.9.0",
    "fs-extra": "^11.2.0",
    "pinia": "^3.0.4",
    "uuid": "^14.0.0",
    "vue": "^3.5.13",
    "vue-router": "4",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@vitejs/plugin-vue": "^6.0.7",
    "concurrently": "^9.1.0",
    "cross-env": "^10.1.0",
    "electron": "^41.7.0",
    "electron-builder": "^26.11.1",
    "sass": "^1.100.0",
    "vite": "^8.0.14",
    "wait-on": "^9.0.10"
  }
}