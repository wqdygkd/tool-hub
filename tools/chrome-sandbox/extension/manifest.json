{
  "manifest_version": 3,
  "name": "Chrome沙箱 Fingerprint",
  "version": "1.0.0",
  "description": "浏览器指纹伪造扩展",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["injected/*.js", "fingerprint-config.json"],
      "matches": ["<all_urls>"]
    }
  ]
}
