{
  "appId": "com.chrome-sandbox.app",
  "productName": "Chrome沙箱",
  "directories": {
    "output": "release"
  },
  "files": [
    "electron/**/*",
    "tools/**/*",
    "dist/**/*",
    "shared/**/*",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "tools/chrome-sandbox/extension",
      "to": "extension"
    }
  ],
  "win": {
    "target": "nsis",
    "icon": "resources/icons/icon.ico"
  },
  "mac": {
    "target": "dmg",
    "icon": "resources/icons/icon.icns"
  },
  "linux": {
    "target": "AppImage",
    "icon": "resources/icons/icon.png"
  },
  "publish": {
    "provider": "github"
  }
}
